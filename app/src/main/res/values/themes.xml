<?xml version="1.0" encoding="utf-8"?>
<!--
    res/values/themes.xml  →  MODE TERANG (Light)
    Pasangan dark-nya ada di res/values-night/themes.xml
-->
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.Jadwalku" parent="Theme.MaterialComponents.DayNight.NoActionBar">

        <!-- Brand color -->
        <item name="colorPrimary">@color/brand_blue</item>
        <item name="colorPrimaryVariant">@color/brand_blue_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">#EEEEEE</item>
        <item name="colorSecondaryVariant">#DDDDDD</item>
        <item name="colorOnSecondary">#000000</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/light_bg_surface</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>

        <!-- Input control colors -->
        <item name="colorControlNormal">@color/input_stroke_default</item>
        <item name="colorControlActivated">@color/brand_blue</item>
        <item name="colorControlHighlight">@color/brand_blue</item>
        <item name="textInputStyle">@style/Widget.Jadwalku.TextInputLayout.OutlinedBox</item>

        <!-- ── Custom semantic color attributes ── -->
        <!-- Background -->
        <item name="colorBgScreen">@color/light_bg_screen</item>
        <item name="colorBgSurface">@color/light_bg_surface</item>
        <item name="colorBgCard">@color/light_bg_card</item>
        <item name="colorBgInput">@color/light_bg_input</item>

        <!-- Text -->
        <item name="colorTextPrimary">@color/light_text_primary</item>
        <item name="colorTextSecondary">@color/light_text_secondary</item>
        <item name="colorTextHint">@color/light_text_hint</item>
        <item name="colorTextOnCard">@color/light_text_on_card</item>

        <!-- Stroke input -->
        <item name="colorInputStroke">@color/light_input_stroke</item>
    </style>

    <!-- TextInputLayout custom style -->
    <style name="Widget.Jadwalku.TextInputLayout.OutlinedBox"
        parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/input_box_stroke</item>
        <item name="hintTextColor">@color/brand_blue</item>
        <item name="boxCornerRadiusTopStart">8dp</item>
        <item name="boxCornerRadiusTopEnd">8dp</item>
        <item name="boxCornerRadiusBottomStart">8dp</item>
        <item name="boxCornerRadiusBottomEnd">8dp</item>
    </style>

</resources>