<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.kelompok.jadwalku">

    <application
        android:name=".PengingatApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="Jadwalku"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.Light.NoActionBar">

        <activity android:name=".LoginActivity" android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".MainActivity" />
        <activity android:name=".TambahJadwalActivity" />
        <activity android:name=".TambahTugasActivity" />
        <activity android:name=".PengingatActivity" />
        <activity android:name=".NotifikasiActivity" />
    </application>

</manifest>